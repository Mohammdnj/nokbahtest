# ============================================================
# Nokba — unified web root (static Next.js + PHP API)
# ============================================================

RewriteEngine On
Options -MultiViews

# ------------------------------------------------------------
# API routing — must come BEFORE Next.js SPA fallback
# ------------------------------------------------------------

# Pretty URL: /api/contracts/commercial/{action}
RewriteRule ^api/contracts/commercial/([a-z\-]+)/?$ api/commercial-contract.php?action=$1 [L,QSA]

# Pretty URL: /api/lookups/{action}
RewriteRule ^api/lookups/([a-z\-]+)/?$ api/lookups.php?action=$1 [L,QSA]

# Default: /api/{name}  ->  api/{name}.php  (preserving query string)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/([a-zA-Z0-9_\-]+)/?$ api/$1.php [L,QSA]

# ------------------------------------------------------------
# Static frontend — let existing files serve normally
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ------------------------------------------------------------
# Next.js static export — append .html for pages like /login
# ------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [L]

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
<FilesMatch "\.(env|sql|log)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
</IfModule>

# Compress text responses
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
